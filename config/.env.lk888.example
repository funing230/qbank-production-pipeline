# Optional second image provider for run_production_v7_queue.py
# Copy only the needed lines into config/.env during a controlled restart.
# Never paste the real key into chat/logs.

LK888_IMAGE_BASE_URL_2=https://api.lk888.ai/v1
LK888_IMAGE_MODEL_2=gpt-image-2
LK888_IMAGE_SIZE_2=1024x1024
LK888_IMAGE_API_KEY_2=REPLACE_WITH_REAL_KEY_LOCALLY

# Start at 20, then ramp 20 -> 28 -> 36 -> 42 -> 48.
LK888_IMAGE_CONCURRENCY_2=20
LK888_IMAGE_RAMP_STEPS_2=20,28,36,42,48

# lk888 async media task polling.
GPT_IMAGE_LK888_POLL_INTERVAL=5
GPT_IMAGE_LK888_TIMEOUT=240
